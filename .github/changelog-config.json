{
    "categories": [
        {
            "title": "## 🚀 Features",
            "labels": [
                "feature",
                "enhancement"
            ]
        },
        {
            "title": "## 🐛 Bug Fixes",
            "labels": [
                "bug",
                "fix",
                "bugfix"
            ]
        },
        {
            "title": "## 🔧 Improvements",
            "labels": [
                "improvement",
                "refactor",
                "perf",
                "performance"
            ]
        },
        {
            "title": "## 📦 Dependencies",
            "labels": [
                "dependencies",
                "deps"
            ]
        },
        {
            "title": "## 📝 Other",
            "labels": []
        }
    ],
    "template": "#{{CHANGELOG}}\n\n**Full Changelog**: #{{RELEASE_DIFF}}",
    "pr_template": "- #{{TITLE}} (#{{NUMBER}})",
    "empty_template": "No notable changes.",
    "max_pull_requests": 50,
    "sort": {
        "order": "ASC",
        "on_property": "mergedAt"
    }
}
