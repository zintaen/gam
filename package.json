{
    "name": "gam",
    "type": "module",
    "version": "1.0.11",
    "description": "Git Alias Manager — A professional desktop GUI for managing Git aliases",
    "author": "zintaen <zintaen@example.com>",
    "license": "MIT",
    "homepage": "https://github.com/zintaen/gam#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/zintaen/gam.git"
    },
    "bugs": {
        "url": "https://github.com/zintaen/gam/issues"
    },
    "keywords": [
        "git",
        "alias",
        "manager",
        "tauri",
        "desktop"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "ai:setup": "cyberskill ai:setup",
        "build": "dotenv -- tauri build --target universal-apple-darwin",
        "dev": "tauri dev",
        "inspect": "cyberskill inspect",
        "lint": "cyberskill lint",
        "lint:fix": "cyberskill lint:fix",
        "lint:inspect": "cyberskill lint:inspect",
        "preview": "vite preview",
        "ready": "cyberskill ready",
        "release": "node scripts/release.js",
        "reset": "cyberskill reset",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "vite": "vite",
        "vite:build": "vite build"
    },
    "dependencies": {
        "@cyberskill/shared": "3.1.0",
        "@tauri-apps/api": "2.10.1",
        "@tauri-apps/plugin-process": "2.3.1",
        "@tauri-apps/plugin-updater": "2.10.0",
        "npm-run-all2": "8.0.4",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.3",
        "@commitlint/config-conventional": "20.4.3",
        "@playwright/test": "1.58.2",
        "@tailwindcss/postcss": "4.2.1",
        "@tauri-apps/cli": "2.10.0",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "25.3.3",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.1.4",
        "@vitest/coverage-v8": "4.0.18",
        "autoprefixer": "10.4.27",
        "dotenv-cli": "11.0.0",
        "eslint": "10.0.2",
        "jsdom": "28.1.0",
        "lint-staged": "16.3.2",
        "postcss": "8.5.8",
        "puppeteer": "24.37.5",
        "simple-git-hooks": "2.13.1",
        "tailwindcss": "4.2.1",
        "typescript": "5.9.3",
        "vite": "7.3.1",
        "vitest": "4.0.18"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ],
        "overrides": {
            "minimatch@<10.2.3": ">=10.2.3"
        }
    }
}
